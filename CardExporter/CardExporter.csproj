<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <LangVersion>Latest</LangVersion>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <EnableWindowsTargeting Condition="'$(OS)' != 'Windows_NT'">true</EnableWindowsTargeting>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AWSSDK.S3"
                      Version="3.7.511.8" />
    <PackageReference Include="ICSharpCode.BamlDecompiler"
                      Version="9.0.0.7889" />
    <PackageReference Include="MTGOSDK"
                      Version="1.5.1.20260622" />
    <PackageReference Include="MTGOSDK.Win32"
                      Version="1.5.1.20260622" />
    <PackageReference Include="Microsoft.Extensions.Logging"
                      Version="10.0.3" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console"
                      Version="10.0.3" />
    <PackageReference Include="Npgsql"
                      Version="10.0.3" />
    <PackageReference Include="System.Drawing.Common"
                      Version="10.0.3" />
  </ItemGroup>
</Project>
